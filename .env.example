# Backend API base URL (no trailing slash). Rebuild after changing (npm run build).
# Override for local dev: VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=https://api-neomed.encryptedbar.com

# --- Firebase Web (FCM browser push) — public keys only; never commit real .env ---
# Firebase Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Cloud Messaging → Web Push certificates → Key pair (public key only)
VITE_FIREBASE_VAPID_KEY=
